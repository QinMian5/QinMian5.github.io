---
import BaseItemCard from "../components/BaseItemCard.astro";
import ContentHeader from "../components/ContentHeader.astro";
import {
  formatDate,
  getEntryAuthors,
  getEntryExtra,
  getEntryPath,
  type PublicCollection,
  type PublicEntry,
} from "../lib/content";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  collection: PublicCollection;
  title: string;
  subtitle?: string;
  entries: PublicEntry[];
}

const { collection, title, subtitle, entries } = Astro.props;
const isEmpty = entries.length === 0;
const description = subtitle ?? `${title} by Mian Qin.`;
---

<BaseLayout title={title} description={description} noindex={isEmpty}>
  <ContentHeader title={title} subtitle={subtitle} />
  <section class="item-list" aria-label={title}>
    {
      !isEmpty
        ? entries.map((entry) => (
            <BaseItemCard
              title={entry.data.title}
              href={getEntryPath(collection, entry)}
              description={entry.data.description}
              date={formatDate(entry.data.date)}
              authors={getEntryAuthors(entry)}
              extra={getEntryExtra(entry)}
              tags={entry.data.tags}
              externalUrl={entry.data.externalUrl}
            />
          ))
        : null
    }
  </section>
</BaseLayout>

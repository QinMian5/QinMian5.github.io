---
import { getEntry, render } from "astro:content";
import BackLink from "../components/BackLink.astro";
import ContentHeader from "../components/ContentHeader.astro";
import ShareButtons from "../components/ShareButtons.astro";
import {
  collectionLabels,
  collectionPaths,
  formatDate,
  getEntryAuthors,
  getEntryExtra,
  type PublicCollection,
  type PublicEntry,
} from "../lib/content";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  collection: PublicCollection;
  id: string;
}

const { collection, id } = Astro.props;
const entry = (await getEntry(collection, id)) as PublicEntry | undefined;

if (!entry || entry.data.draft === true) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
const canonicalUrl = new URL(Astro.url.pathname, "https://qinmian5.github.io")
  .href;
const extra = getEntryExtra(entry);
const authors = getEntryAuthors(entry);
const meta = [
  entry.data.date
    ? {
        icon: "Calendar",
        value: formatDate(entry.data.date) ?? "",
        datetime: entry.data.date.toISOString(),
      }
    : undefined,
  authors ? { icon: "User", value: authors } : undefined,
  extra ? { icon: "Institution", value: extra } : undefined,
].filter((item): item is { icon: string; value: string; datetime?: string } =>
  Boolean(item),
);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description ?? collectionLabels[collection]}
  ogType="article"
>
  <div class="detail-toolbar">
    <BackLink
      href={collectionPaths[collection]}
      label={collectionLabels[collection]}
    />
    {
      entry.data.externalUrl ? (
        <a
          class="text-link"
          href={entry.data.externalUrl}
          target="_blank"
          rel="noreferrer"
        >
          View external
        </a>
      ) : null
    }
  </div>
  <article class="page-section prose-page">
    <ContentHeader
      title={entry.data.title}
      subtitle={entry.data.description}
      meta={meta}
      tags={entry.data.tags}
    />
    <div class="prose">
      <Content />
    </div>
    <ShareButtons title={entry.data.title} url={canonicalUrl} />
  </article>
</BaseLayout>

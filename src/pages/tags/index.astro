---
import EmptyState from "../../components/EmptyState.astro";
import Tag from "../../components/Tag.astro";
import { pages } from "../../config/site";
import { getAllTags } from "../../lib/content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const tags = await getAllTags();
const maxCount = Math.max(...tags.map((tag) => tag.count), 0);
const minCount = Math.min(...tags.map((tag) => tag.count), 0);

function getTagSize(count: number): "sm" | "md" | "lg" {
  if (tags.length < 5 || maxCount === minCount) {
    return "md";
  }

  const normalized = (count - minCount) / (maxCount - minCount);
  if (normalized > 0.7) {
    return "lg";
  }
  if (normalized > 0.3) {
    return "md";
  }
  return "sm";
}
---

<BaseLayout
  title={pages.tags.title}
  description={pages.tags.subtitle}
  noindex={true}
>
  <section class="page-section" aria-labelledby="tags-title">
    <p class="eyebrow">Tags</p>
    <h2 id="tags-title" class="page-title">{pages.tags.title}</h2>
    <p class="page-subtitle">{pages.tags.subtitle}</p>
    {
      tags.length > 0 ? (
        <div class="tag-cloud">
          {tags.map((tag) => (
            <Tag
              name={tag.name}
              count={tag.count}
              size={getTagSize(tag.count)}
            />
          ))}
        </div>
      ) : (
        <EmptyState
          title={pages.tags.emptyTitle}
          message={pages.tags.emptyMessage}
        />
      )
    }
  </section>
</BaseLayout>

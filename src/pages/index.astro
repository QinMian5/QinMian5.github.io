---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section
    class="mx-auto flex min-h-dvh max-w-3xl flex-col justify-center px-6 py-16 sm:px-8"
  >
    <p class="mb-3 text-sm font-medium text-[color:var(--color-muted)]">
      Personal website
    </p>
    <h1
      class="text-4xl font-semibold tracking-normal text-[color:var(--color-text)] sm:text-5xl"
    >
      Mian Qin
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--color-muted)]">
      Researcher and developer working on molecular simulation, scientific
      computing, and agentic research infrastructure.
    </p>
  </section>
</BaseLayout>

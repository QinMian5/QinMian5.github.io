---
import { getSectionEntries } from "../../lib/content";
import BaseDetail from "../../layouts/BaseDetail.astro";

export async function getStaticPaths() {
  const entries = await getSectionEntries("projects");
  return entries.map((entry) => ({ params: { id: entry.id } }));
}

const { id } = Astro.params;
---

<BaseDetail collection="projects" id={id ?? ""} />

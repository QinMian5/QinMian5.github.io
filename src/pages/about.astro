---
import { getEntry, render } from "astro:content";
import EducationList from "../components/EducationList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const entry = await getEntry("pages", "about");

if (!entry) {
  throw new Error("Missing about content entry.");
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={true}
>
  <article class="page-section prose-page" aria-labelledby="about-title">
    <h2 id="about-title" class="page-title">{entry.data.title}</h2>
    <div class="prose">
      <Content />
    </div>
  </article>

  <section class="page-section" aria-labelledby="about-education-title">
    <h2 id="about-education-title" class="section-title">Education</h2>
    <EducationList />
  </section>
</BaseLayout>

---
import Icon from "./Icon.astro";
---

<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  aria-label="Switch color theme"
  aria-pressed="false"
>
  <span class="theme-toggle-icon" aria-hidden="true">
    <Icon name="Sun" size={16} />
  </span>
  <span data-theme-toggle-label>Theme</span>
</button>

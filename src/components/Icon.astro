---
import { icons } from "../assets/icons";

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = "" } = Astro.props;
const content = icons[name];

if (!content) {
  throw new Error(`Unknown icon: ${name}`);
}
---

<span
  class:list={["icon", className]}
  style={`--icon-size: ${size}px`}
  aria-hidden="true"
  set:html={content}
/>
